FIREBASE_PROJECT_ID=portfolio-1a377
FIREBASE_CREDENTIALS_HOST_PATH=./lol/serviceAccountKey.json
CORS_ORIGINS=http://localhost:8080

FRONTEND_BIND_ADDRESS=0.0.0.0
FRONTEND_PORT=8080
BACKEND_BIND_ADDRESS=127.0.0.1
MONITORING_BIND_ADDRESS=127.0.0.1
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

MONGO_URL=mongodb://mongodb:27017/shop

# Incident simulation:
# Break Order/Product/Chat database access by changing Mongo hostname:
# MONGO_URL=mongodb://wrong-mongodb:27017/shop

# VM example:
# FRONTEND_PORT=80
# CORS_ORIGINS=http://YOUR_VM_PUBLIC_IP
# Keep BACKEND_BIND_ADDRESS=127.0.0.1 so ports 4000-4004 and 27017 stay closed externally.
# Keep MONITORING_BIND_ADDRESS=127.0.0.1 and access Grafana/Prometheus through SSH tunnels.
